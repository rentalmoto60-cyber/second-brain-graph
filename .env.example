# --- Required for AI parsing of voice / text thoughts + coach ---
# Get a free key at https://aistudio.google.com/apikey (1500 req/day on free tier)
GEMINI_API_KEY=your-gemini-key

# Override the model if needed (defaults to gemini-1.5-flash)
# GEMINI_MODEL=gemini-2.0-flash

# --- Speech-to-text (pick ONE) ---

# Option A: cloud Whisper (recommended; fastest setup)
# OPENAI_API_KEY=sk-...
# WHISPER_MODEL=whisper-1

# Option B: local faster-whisper (fallback if OPENAI_API_KEY is unset)
#   pip install faster-whisper
# LOCAL_WHISPER_MODEL=small

# --- HTTP Basic Auth (single-user gate) ---
# Generate the hash with: python scripts/hash_password.py 'mypass'
# If APP_USERNAME or APP_PASSWORD_HASH is unset, auth is disabled (dev mode).
APP_USERNAME=maksim
APP_PASSWORD_HASH=$2b$12$replace-me-with-real-hash

# --- Reverse-proxy / hosts ---
# Comma-separated list of allowed Host headers, or `*` for any (dev).
# In production set to your real domain, e.g. brain.example.com
ALLOWED_HOSTS=*
# Trust X-Forwarded-* from these proxy IPs (set to your nginx IP on prod).
# FORWARDED_ALLOW_IPS=127.0.0.1

# --- Storage ---
# Where brain.json lives. On a VPS: /opt/second-brain/data/brain.json
# STORAGE_PATH=/opt/second-brain/data/brain.json

# --- Server bind (used by app.py) ---
# HOST=0.0.0.0
# PORT=8000
